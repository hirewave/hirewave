# You can use this file to easily send requests to your API.
# Prerequisite: humao.rest-client Vscode plugin (already present on codespace)
# High-level overview of REST API concepts used here: https://www.packtpub.com/en-us/learning/how-to-tutorials/what-are-rest-verbs-and-status-codes-tutorial

# TIP: Run requests in order - later requests reference IDs from earlier responses


# ==========================================
# User Controller Endpoints
# ==========================================

### Get all users
GET http://localhost:8080/api/users

### Create a new user (run this to populate variables for other requests)
# @name createUser
POST http://localhost:8080/api/users
Content-Type: application/json

{
    "name": "Jean Valjean",
    "email": "prisoner24601@france.fr"
}

### Get user by ID (uses ID from createUser response)
GET http://localhost:8080/api/users/{{createUser.response.body.id}}

### Get user by email (uses email from createUser response)
GET http://localhost:8080/api/users/by-email?email={{createUser.response.body.email}}

### Update user name (PUT)
PUT http://localhost:8080/api/users/{{createUser.response.body.id}}
Content-Type: application/json

{
    "name": "Monsieur Madeleine"
}

### Change user name (PATCH)
PATCH http://localhost:8080/api/users/{{createUser.response.body.id}}/name
Content-Type: application/json

{
    "name": "Monsieur le Maire"
}


# ==========================================
# Todo Controller Endpoints
# ==========================================

### Create a new todo (run this after createUser to populate variables)
# @name createTodo
POST http://localhost:8080/api/todos
Content-Type: application/json

{
    "description": "Rescue Cosette from the Thénardiers",
    "assigneeEmail": "{{createUser.response.body.email}}"
}

### Get todos by assignee email
GET http://localhost:8080/api/todos?assigneeEmail={{createUser.response.body.email}}

### Get todo by ID (uses ID from createTodo response)
GET http://localhost:8080/api/todos/{{createTodo.response.body.id}}

### Mark todo as done
PATCH http://localhost:8080/api/todos/{{createTodo.response.body.id}}/done
Content-Type: application/json

true

### Assign todo to another user
# Note: You'll need another user to exist for this to work
PATCH http://localhost:8080/api/todos/{{createTodo.response.body.id}}/assignee
Content-Type: application/json

{
    "newAssigneeEmail": "frodo@theshire.me"
}

### Edit todo description
PATCH http://localhost:8080/api/todos/{{createTodo.response.body.id}}/description
Content-Type: application/json

{
    "description": "Escape from Inspector Javert"
}


# ==========================================
# Client Controller Endpoints
# ==========================================

### Get all clients
GET http://localhost:8080/api/clients

### Create a new client (run this to populate variables for other requests)
# @name createClient
POST http://localhost:8080/api/clients
Content-Type: application/json

{
    "name": "Broski Corporation",
    "email": "hiring@broski.io"
}

### Get client by ID (uses ID from createClient response)
GET http://localhost:8080/api/clients/{{createClient.response.body.id}}

### Update client (PUT)
PUT http://localhost:8080/api/clients/{{createClient.response.body.id}}
Content-Type: application/json

{
    "name": "Broski Corporation Ltd",
    "email": "projects@broski.io"
}

### Delete client
DELETE http://localhost:8080/api/clients/{{createClient.response.body.id}}


# ==========================================
# Freelancer Controller Endpoints
# ==========================================

### Get all freelancers
GET http://localhost:8080/api/freelancers

### Create a new freelancer (run this to populate variables for other requests)
# @name createFreelancer
POST http://localhost:8080/api/freelancers
Content-Type: application/json

{
    "name": "Terry Davis",
    "email": "terry@templeos.org",
    "skills": ["C", "Assembly", "OS Development"],
    "hourlyRate": 100.0
}

### Get freelancer by ID (uses ID from createFreelancer response)
GET http://localhost:8080/api/freelancers/{{createFreelancer.response.body.id}}

### Update freelancer (PUT)
PUT http://localhost:8080/api/freelancers/{{createFreelancer.response.body.id}}
Content-Type: application/json

{
    "name": "Terry A. Davis",
    "email": "terry@templeos.org",
    "skills": ["C", "Assembly", "OS Development", "HolyC"],
    "hourlyRate": 110.0
}

### Rate a freelancer
POST http://localhost:8080/api/freelancers/{{createFreelancer.response.body.id}}/ratings
Content-Type: application/json

{
    "rating": 5
}

### Delete freelancer
DELETE http://localhost:8080/api/freelancers/{{createFreelancer.response.body.id}}


# ==========================================
# Project Controller Endpoints
# ==========================================

### Get all projects
GET http://localhost:8080/api/projects

### Create a new project (run after createClient)
# @name createProject
POST http://localhost:8080/api/projects
Content-Type: application/json

{
    "title": "Build a REST API",
    "description": "We need a scalable REST API built with Java and Spring Boot",
    "clientId": "{{createClient.response.body.id}}",
    "requiredSkills": ["Java", "Spring Boot", "MongoDB"],
    "budget": 5000.0
}

### Get project by ID
GET http://localhost:8080/api/projects/{{createProject.response.body.id}}

### Get projects by client ID
GET http://localhost:8080/api/projects/by-client/{{createClient.response.body.id}}

### Update project (only works when OPEN)
PUT http://localhost:8080/api/projects/{{createProject.response.body.id}}
Content-Type: application/json

{
    "title": "Build a Scalable REST API",
    "description": "Updated: We need a highly scalable REST API with full test coverage",
    "requiredSkills": ["Java", "Spring Boot", "MongoDB", "Docker"],
    "budget": 6000.0
}

### Cancel project (OPEN → CANCELLED)
PATCH http://localhost:8080/api/projects/{{createProject.response.body.id}}/cancel

### Complete project (IN_PROGRESS → COMPLETED - run after accepting a bid)
PATCH http://localhost:8080/api/projects/{{createProject.response.body.id}}/complete


# ==========================================
# Bid Controller Endpoints
# ==========================================

### Get all bids for a project
GET http://localhost:8080/api/bids?projectId={{createProject.response.body.id}}

### Submit a bid (run after createProject and createFreelancer)
# @name createBid
POST http://localhost:8080/api/bids
Content-Type: application/json

{
    "projectId": "{{createProject.response.body.id}}",
    "freelancerId": "{{createFreelancer.response.body.id}}",
    "amount": 4500.0,
    "message": "I have 5 years of Java + Spring Boot experience and can deliver on time."
}

### Get bid by ID
GET http://localhost:8080/api/bids/{{createBid.response.body.id}}

### Accept a bid (cascade: other bids rejected, project → IN_PROGRESS)
PATCH http://localhost:8080/api/bids/{{createBid.response.body.id}}/accept

### Reject a bid manually
PATCH http://localhost:8080/api/bids/{{createBid.response.body.id}}/reject


# ==========================================
# Cleanup (run these last)
# ==========================================

### Delete todo
DELETE http://localhost:8080/api/todos/{{createTodo.response.body.id}}

### Delete user
DELETE http://localhost:8080/api/users/{{createUser.response.body.id}}

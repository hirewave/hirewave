                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{"name":"PerfFreelancerA-${__threadNum}","email":"perf-freelancer-a-${__threadNum}-${__time(YMDHMS)}-${__Random(1000,9999)}@example.com","skills":["Java","Spring Boot"],"hourlyRate":50.0}</stringProp>
